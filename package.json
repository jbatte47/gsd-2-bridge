  "type": "module",
  "bugs": {
    "url": "https://github.com/jbatte47/gsd-2-bridge/issues"
  },
  "homepage": "https://github.com/jbatte47/gsd-2-bridge#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "obsidian": "^1.12.3",
    "tslib": "^2.8.1"
  }
}
