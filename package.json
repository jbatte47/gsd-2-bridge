{
  "name": "gsd-2-bridge",
  "version": "1.0.0",
  "description": "Obsidian plugin that syncs markdown task sources with local GSD-2 workflows and can dispatch ready work to the GSD-2 CLI.",
  "main": "main.js",
  "scripts": {
    "test": "npm run build",
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jbatte47/gsd-2-bridge.git"
  },
  "keywords": [],
